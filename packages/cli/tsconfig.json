    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "composite": true
  },
  "include": [
    "src"
  ],
  "references": [
