{
  "name": "@galaxy-graph/core",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/style.css dist/style.css",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "3d-force-graph": "^1.79.0",
    "three": "^0.169.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0"
  },
  "description": "React renderer and normalized graph schema for Galaxy Graph",
  "author": "Ben Sheridan Edwards",
  "repository": {
    "type": "git",
    "url": "https://github.com/BenSheridanEdwards/galaxy-graph.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/BenSheridanEdwards/galaxy-graph#readme",
  "bugs": {
    "url": "https://github.com/BenSheridanEdwards/galaxy-graph/issues"
  },
  "keywords": [
    "galaxy-graph",
    "react",
    "threejs",
    "3d-force-graph"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
